{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Feature List Schema",
  "description": "Schema for long-running agent feature tracking",
  "type": "object",
  "required": ["project", "version", "created_at", "features"],
  "properties": {
    "project": {
      "type": "string",
      "description": "Project name"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Project version (semver)"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO timestamp of feature list creation"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO timestamp of last update"
    },
    "total_features": {
      "type": "integer",
      "minimum": 0,
      "description": "Total number of features"
    },
    "passing_features": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of passing features"
    },
    "features": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/feature"
      },
      "minItems": 1
    }
  },
  "definitions": {
    "feature": {
      "type": "object",
      "required": ["id", "category", "priority", "description", "passes"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^F\\d{3,}$",
          "description": "Unique feature identifier (e.g., F001)"
        },
        "category": {
          "type": "string",
          "enum": [
            "functional",
            "ui",
            "api",
            "database",
            "security",
            "performance",
            "accessibility",
            "integration",
            "error_handling",
            "configuration"
          ],
          "description": "Feature category"
        },
        "priority": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low"],
          "description": "Feature priority level"
        },
        "description": {
          "type": "string",
          "minLength": 10,
          "description": "Clear description of the feature"
        },
        "steps": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Step-by-step instructions to test the feature"
        },
        "acceptance_criteria": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Measurable criteria for completion"
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^F\\d{3,}$"
          },
          "description": "Feature IDs that must be completed first"
        },
        "passes": {
          "type": ["boolean", "string"],
          "enum": [true, false, "skipped"],
          "default": false,
          "description": "Feature status: true (passing), false (pending), 'skipped' (blocked)"
        },
        "skip_reason": {
          "type": ["string", "null"],
          "description": "Reason for skipping the feature"
        },
        "last_tested": {
          "type": ["string", "null"],
          "format": "date-time",
          "description": "ISO timestamp of last test"
        },
        "tested_by": {
          "type": ["string", "null"],
          "enum": ["unit_test", "e2e_test", "browser_automation", "manual", null],
          "description": "Method used to test"
        },
        "implementation_notes": {
          "type": "string",
          "description": "Notes about the implementation"
        },
        "test_file": {
          "type": "string",
          "description": "Path to test file"
        },
        "estimated_complexity": {
          "type": "string",
          "enum": ["trivial", "simple", "medium", "complex"],
          "description": "Estimated implementation complexity"
        }
      }
    }
  }
}